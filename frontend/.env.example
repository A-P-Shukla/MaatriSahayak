# The base URL for the backend API Gateway
VITE_API_BASE_URL=http://localhost:3000

# WebSocket URL for real-time updates (optional)
# For production: wss://your-api-gateway-url/dev
# For local development: ws://localhost:3001
VITE_WS_URL=ws://localhost:3001

# API timeout in milliseconds (default: 10000 = 10 seconds)
VITE_API_TIMEOUT=10000

# Maximum number of retry attempts for failed requests (default: 3)
VITE_API_MAX_RETRIES=3

# AWS Configuration
# AWS region where your resources are deployed
VITE_AWS_REGION=ap-south-1

# AWS Cognito User Pool ID for authentication
# Format: {region}_{random-string}
VITE_COGNITO_USER_POOL_ID=ap-south-1_1RZVdy6wo
# AWS Cognito App Client ID
VITE_COGNITO_CLIENT_ID=395kbobt018n43eod438sdqf29

# Username: testasha@example.com
# Password: NewPass123!

# Map Configuration
# OpenStreetMap tile server URL
# {s} = subdomain (a, b, or c), {z} = zoom level, {x}/{y} = tile coordinates
VITE_MAP_TILES_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# Map attribution text (required by OpenStreetMap)
VITE_MAP_ATTRIBUTION=&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors

VITE_APP_NAME=MaatriSahayak Dashboard

# Application version
VITE_APP_VERSION=1.0.0

# LocalStorage Keys (optional - defaults provided)
# Keys used for storing authentication data in browser localStorage
VITE_AUTH_TOKEN_KEY=auth_token
VITE_REFRESH_TOKEN_KEY=refresh_token
VITE_ID_TOKEN_KEY=id_token
VITE_USER_DATA_KEY=user_data